{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "resolveJsonModule": true
  },
  "include": [
    "server/**/*.ts",
    "src/domain/connectedContracts.ts",
    "src/domain/contracts.ts",
    "src/domain/researchContracts.ts",
    "src/domain/validation.ts"
  ]
}
